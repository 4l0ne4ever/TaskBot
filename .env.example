# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
# After Google OAuth, backend redirects here with JWT in URL fragment (#access_token=...)
FRONTEND_URL=http://localhost:3000

# Clerk (Frontend Auth) — Next.js uses NEXT_PUBLIC_; Vite uses VITE_
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# LLM
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=taskExtractor

# Database — when using Docker Compose, compose overrides this to host `postgres` (keep for local non-Docker runs)
DATABASE_URL=postgresql+asyncpg://taskbot:taskbot@localhost:5432/taskbot

# Redis — Compose overrides to `redis://redis:6379` inside the stack
REDIS_URL=redis://localhost:6379

# BACKEND_API_BASE_URL — agent uses http://backend:8000 inside Compose; use http://127.0.0.1:8000 when running agent on host
BACKEND_API_BASE_URL=http://127.0.0.1:8000

# MCP — in-repo HTTP bridges for Gmail and Drive (Docker services mcp-gmail, mcp-drive).
# Compose overrides GMAIL_MCP_URL and DRIVE_MCP_URL to use service hostnames.
# For host-only dev, use localhost + published ports.
GMAIL_MCP_URL=http://127.0.0.1:8788/mcp
DRIVE_MCP_URL=http://127.0.0.1:8787/mcp
CALENDAR_MCP_URL=https://gcal.mcp.claude.com/mcp

# Security
JWT_SECRET=replace-with-strong-secret
ENCRYPTION_KEY=replace-with-valid-fernet-key

# AWS (IAM User - programmatic access)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=taskbot-uploads-dev
PIPELINE_QUEUE_NAME=pipeline:jobs

# App
SYNC_GMAIL_INTERVAL_MINUTES=15
SYNC_DRIVE_INTERVAL_MINUTES=30

# Frontend (Next.js) — browser calls backend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Docker Compose — published host ports (optional overrides)
# POSTGRES_PUBLISH_PORT=5433
# REDIS_PUBLISH_PORT=6380
# BACKEND_PUBLISH_PORT=8000
# FRONTEND_PUBLISH_PORT=3000
# MCP_DRIVE_PUBLISH_PORT=8787
# If only Postgres/Redis ports change on the host, also adjust DATABASE_URL / REDIS_URL for tools running on the host (not inside Compose).

# E2E — real Google account checks (scripts/mcp_real_account_check.py); never commit a real token
# E2E_GOOGLE_ACCESS_TOKEN=
# E2E_EXPECT_GOOGLE_EMAIL=
