# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# LLM
GEMINI_API_KEY=

# Database
DATABASE_URL=postgresql+asyncpg://taskbot:taskbot@localhost:5432/taskbot

# Redis
REDIS_URL=redis://localhost:6379

# MCP
GMAIL_MCP_URL=https://gmail.mcp.claude.com/mcp
DRIVE_MCP_URL=
BACKEND_API_BASE_URL=http://127.0.0.1:8000

# Security
JWT_SECRET=replace-with-strong-secret
ENCRYPTION_KEY=replace-with-valid-fernet-key

# AWS (IAM User - programmatic access)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=taskbot-uploads-dev
PIPELINE_QUEUE_NAME=pipeline:jobs

# App
SYNC_GMAIL_INTERVAL_MINUTES=15
SYNC_DRIVE_INTERVAL_MINUTES=30
