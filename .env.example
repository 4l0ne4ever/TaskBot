# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
# After Google OAuth, backend redirects here with JWT in URL fragment (#access_token=...)
FRONTEND_URL=http://localhost:3000

# Clerk (Frontend Auth) — Next.js uses NEXT_PUBLIC_; Vite uses VITE_
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# LLM
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile
# When 1: Groq rate-limit errors do not fall back to GROQ_FALLBACK_MODEL (fail fast). Eval uses production routing unless EVAL_GEMINI_ONLY pins Gemini.
# GROQ_STRICT_PRIMARY=0
# When 1: if all Groq keys are exhausted, do not call Gemini (for gpt-oss-only eval / sweep).
# GROQ_DISABLE_GEMINI_FALLBACK=0
# Optional: primary model for eval only (run_eval pipeline). If unset, eval uses GROQ_MODEL above.
# EVAL_GROQ_MODEL=openai/gpt-oss-120b
# GEMINI_API_KEY=   (or GOOGLE_API_KEY — both map to the same setting)
# GEMINI_MODEL=gemini-2.5-flash
# HTTP timeout for Gemini API calls (seconds); on timeout the pipeline falls back to Groq when allowed.
# GEMINI_HTTP_TIMEOUT_SECONDS=120
# Cap google-genai HTTP retries (unset = SDK default, often 5 attempts on 408/429/5xx). Set 1 to avoid N×timeout wall time while debugging.
# GEMINI_HTTP_RETRY_ATTEMPTS=1
# Log model/thinking_budget/timeout/retry to app logger at INFO (verify .env is loaded).
# GEMINI_DEBUG=1
# Gemini 2.5 Flash thinking: 0 = off (faster); -1 = dynamic thinking (higher latency, API default when omitted).
# GEMINI_THINKING_BUDGET=0
# Worker: background Gemini ping on startup (non-blocking; helps cold TLS/session before pipeline jobs).
# GEMINI_WARMUP_ON_WORKER_START=true
# APScheduler: periodic Gemini ping (minutes); unset = off. Example: 5
# GEMINI_KEEPALIVE_INTERVAL_MINUTES=

# LangSmith (optional)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=taskExtractor
LANGSMITH_API_URL=https://api.smith.langchain.com
# HTTP timeout for LangSmith /runs ingest (seconds); failures are counted in Redis obs:langsmith:ingest:*
# LANGSMITH_INGEST_TIMEOUT_SECONDS=5
# Max retry attempts for LangSmith POST (retries on 5xx/429 with exponential backoff + jitter)
# LANGSMITH_INGEST_MAX_RETRIES=3
# Base seconds for exponential backoff between retries: delay = base * 2^attempt + jitter(0, base)
# LANGSMITH_INGEST_RETRY_BACKOFF_BASE_SECONDS=1.0
# Optional: group eval runs in LangSmith (default: eval-pipeline-<EVAL_RUN_ID> set by run_eval)
# LANGSMITH_SESSION_NAME=my-eval-batch

# Pipeline eval: strict primary only (default groq_model / gpt-oss-120b), no Llama/Gemini — stop on daily quota + resume (see run_eval docstring)
# EVAL_STRICT_PRIMARY_MODEL_ONLY=1
# Abort eval run when Groq daily quota (TPD/RPD) hits mid-batch; writes partial JSON to --output (default on). Re-run the same command to merge remaining samples (no separate --resume path required).
# EVAL_ABORT_ON_DAILY_QUOTA=1
# Eval / sweep: use only Gemini when GEMINI_API_KEY is set (no Groq fallback on provider errors)
# EVAL_GEMINI_ONLY=1
# Eval / sweep: use only Cerebras (gpt-oss-120b) — no Groq/Gemini. Requires CEREBRAS_API_KEY.
# EVAL_CEREBRAS_ONLY=1
# CEREBRAS_API_KEY=
# CEREBRAS_MODEL=gpt-oss-120b
# CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
# run_eval.py: print progress every N samples (default 1; set 10 for quieter logs)
# EVAL_PROGRESS_EVERY=1
# Eval: seconds between pipeline samples (reduce 429s; default 8)
# EVAL_RPM_INTERVAL_SECONDS=12
# After every N pipeline samples, pause longer (0 = disable)
# EVAL_BATCH_COOLDOWN_EVERY=20
# EVAL_BATCH_COOLDOWN_SECONDS=45
# Between sweep grid cells (run_eval subprocesses)
# EVAL_SWEEP_CELL_COOLDOWN_SECONDS=60
# Policy sweep: after each cell, sweep_policy_thresholds.py updates *_checkpoint.json. On quota, re-run the same flags with sweep --resume; run_eval continues each cell from the existing _sweep_*.json automatically.
GROQ_INPUT_COST_PER_MILLION_TOKENS=0
GROQ_OUTPUT_COST_PER_MILLION_TOKENS=0
MAX_TASKS_PER_DOCUMENT=8
# LLM output cap for extraction (multi-item JSON); default matches Settings in agent/app/config.py
LLM_EXTRACT_MAX_TOKENS=1536
LLM_VERIFY_MAX_TOKENS=1024
# Verify pass source-text cap (characters) to avoid re-sending full documents
LLM_VERIFY_MAX_SOURCE_CHARS=8000
# On extraction retry attempts, progressively truncate very long text chunks
LLM_RETRY_TRUNCATE_CHARS=16000
LLM_RETRY_TRUNCATE_FACTOR=0.7
# Extraction LLM retries per chunk after local JSON repair/parse fails (production default: 3; eval can lower to 1)
EXTRACTION_MAX_RETRIES=3
STRICT_WORK_MAX_GMAIL_MESSAGES_PER_SYNC=20
STRICT_WORK_MAX_DRIVE_FILES_PER_SYNC=20
BALANCED_MAX_GMAIL_MESSAGES_PER_SYNC=30
BALANCED_MAX_DRIVE_FILES_PER_SYNC=30
BROAD_MAX_GMAIL_MESSAGES_PER_SYNC=80
BROAD_MAX_DRIVE_FILES_PER_SYNC=60
LLM_PER_DOCUMENT_COOLDOWN_SECONDS=0.6
LLM_PRESSURE_WINDOW_SIZE=30
LLM_RATE_LIMIT_ERROR_THRESHOLD=0.25
LLM_PRESSURE_MAX_DOCUMENTS_PER_JOB=2
LLM_PRESSURE_REQUEUE_DELAY_SECONDS=45
LLM_PRESSURE_REQUEUE_MAX_RETRIES=3
EVAL_MIN_TITLE_F1=0.75
EVAL_MIN_DEADLINE_EXACT=0.70
EVAL_MIN_NOISE_PRECISION=0.80
# Optional: fail tests/eval/quality_gate.py when calibration ECE exceeds this (unset = skip)
# EVAL_MAX_CALIBRATION_ECE=0.35
# Optional: cap per-retry wait during eval rate limits to avoid long hangs
EVAL_MAX_RATE_LIMIT_WAIT_SECONDS=30
EXTRACT_MERGE_JACCARD_THRESHOLD=0.75
TASK_REUSE_SIMILARITY_THRESHOLD=0.85
CONFLICT_TITLE_SIMILARITY_THRESHOLD=0.70
MAX_CONFLICT_CHECKS_PER_TASK=5
# Defaults align with policy v1 preset in agent/app/pipeline/policies/policies.yaml (post sweep 2026-05)
CONFIDENCE_ABSTAIN_THRESHOLD=0.55
CONFIDENCE_UNCERTAIN_THRESHOLD=0.76
# Pipeline policy preset key loaded from agent/app/pipeline/policies/policies.yaml.
PIPELINE_POLICY_VERSION=v1
# Optional: override YAML thresholds for experiments (tests/eval/sweep_policy_thresholds.py); unset = use policy + CONFIDENCE_* defaults
# PIPELINE_POLICY_CONFIDENCE_ABSTAIN_OVERRIDE=
# PIPELINE_POLICY_CONFIDENCE_UNCERTAIN_OVERRIDE=
# Optional: override conflict-check budget. Set EVAL_ENABLE_CONFLICT_CHECK=0 or PIPELINE_POLICY_MAX_CONFLICT_CHECKS_OVERRIDE=0 for quota-safe candidate generation.
# PIPELINE_POLICY_MAX_CONFLICT_CHECKS_OVERRIDE=
# EVAL_ENABLE_CONFLICT_CHECK=0
# Eval sweep grids (comma-separated floats); used by tests/eval/sweep_policy_thresholds.py defaults
# EVAL_SWEEP_ABSTAIN_GRID=0.45,0.5,0.55,0.6,0.65
# EVAL_SWEEP_UNCERTAIN_GRID=0.7,0.75,0.8,0.82,0.85
# EVAL_SWEEP_COST_FP_NO_TASK=1
# EVAL_SWEEP_COST_FN_TASK=1
# Require at least one clean (non-contaminated) sweep cell before auto-pick/freeze (1=on, 0=off)
# EVAL_SWEEP_REQUIRE_CLEAN_CANDIDATE=1
# Eval assignee: when 1, prefer assignee_canonical then score_names() vs expected (aligned with production resolver); rubric bridge only strips @
# EVAL_CANONICAL_ASSIGNEE=1
# Allow quality gate to pass on partial eval artifacts that aborted early (default off)
# EVAL_ALLOW_ABORTED_PARTIAL=0
# Max runtime errors allowed in eval artifact for quality gate (default 0)
# EVAL_MAX_RUNTIME_ERRORS=0
# Require gate artifact to have no fallback contamination (default on)
# EVAL_REQUIRE_CLEAN_MODEL_PROVENANCE=1
# Allow quality gate to use non-complete freeze artifact (default off; not recommended)
# EVAL_ALLOW_INCOMPLETE_FREEZE=0
# release_quality_flow.py: skip local preflight checks (dataset/policy/env) (1=skip, default run checks)
# EVAL_RELEASE_SKIP_PREFLIGHT=0
# validate_freeze_artifact.py: allow chosen row with contaminated=true (default off)
# EVAL_ALLOW_CONTAMINATED_FREEZE=0
# run_eval: stop after first Groq organization_restricted / account error (default on; set 0 to record all failures)
# EVAL_ABORT_ON_ORGANIZATION_RESTRICTED=1
# sweep_policy_thresholds: stop the whole grid when a cell aborts with organization_restricted (default on)
# EVAL_SWEEP_STOP_ON_ORGANIZATION_RESTRICTED=1
# sweep_policy_thresholds.py: disable per-checkpoint lock (default off; only for manual recovery)
# EVAL_SWEEP_DISABLE_LOCK=0
# sweep_policy_thresholds_offline.py: score only samples not listed in runtime_errors (1=on, default off)
# EVAL_OFFLINE_EXCLUDE_RUNTIME_ERRORS=0
# Optional: path to versioned calibration artifact produced by tests/eval/fit_verbalized_calibration.py
# When set, validate_tasks applies post-hoc confidence remapping before policy threshold bands.
# Artifact fit on 250-sample eval (2026-05-11): CALIBRATION_MATCH_THRESHOLD=0.80, method=isotonic, ECE 0.035→0.001.
# Limitation: artifact fit on same data used for eval (train=test); ece_after is optimistic. Re-fit when held-out eval available.
# CALIBRATION_ARTIFACT_PATH=tests/eval/results/calibration_v1_full250.json

# Database — host-side agent/eval must use the HOST port Docker publishes (see docker-compose.yml).
# Example: OrbStack shows postgres 55432→5432 → use localhost:55432 in DATABASE_URL below.
DATABASE_URL=postgresql+asyncpg://taskbot:taskbot@localhost:5432/taskbot

# Redis — ONE source of truth with Docker Compose:
# • docker-compose maps `${REDIS_PUBLISH_PORT:-6379}:6379`. Use the SAME REDIS_PUBLISH_PORT here as in the
#   `.env` file you pass to `docker compose` so host-side code matches the published port.
# • Example from OrbStack: redis shows 56379→6379 → set REDIS_PUBLISH_PORT=56379 (not 6379).
# • If REDIS_URL is set, it wins over REDIS_HOST+REDIS_PUBLISH_PORT.
REDIS_HOST=127.0.0.1
REDIS_PUBLISH_PORT=6379
# REDIS_URL=redis://127.0.0.1:6379
# If your shell still exports an old REDIS_URL, it overrides .env — run: unset REDIS_URL
# Observability (LLM/pipeline Redis lists): set false to skip Redis writes entirely.
# REDIS_OBSERVABILITY_ENABLED=true
# REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=2

# BACKEND_API_BASE_URL — agent uses http://backend:8000 inside Compose; use http://127.0.0.1:8000 when running agent on host
BACKEND_API_BASE_URL=http://127.0.0.1:8000

# MCP — in-repo HTTP bridges for Gmail and Drive (Docker services mcp-gmail, mcp-drive).
# Compose overrides GMAIL_MCP_URL and DRIVE_MCP_URL to use service hostnames.
# For host-only dev, use localhost + published ports.
GMAIL_MCP_URL=http://127.0.0.1:8788/mcp
DRIVE_MCP_URL=http://127.0.0.1:8787/mcp
CALENDAR_MCP_URL=https://gcal.mcp.claude.com/mcp

# Security
JWT_SECRET=replace-with-strong-secret
ENCRYPTION_KEY=replace-with-valid-fernet-key
INTERNAL_OBSERVABILITY_TOKEN=
TASK_V2_READ_ENABLED=true

# AWS (IAM User - programmatic access)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-1
AWS_S3_BUCKET=taskbot-uploads-dev
PIPELINE_QUEUE_NAME=pipeline:jobs

# App
SYNC_GMAIL_INTERVAL_MINUTES=15
SYNC_DRIVE_INTERVAL_MINUTES=30
DEFAULT_DEADLINE_DAYS_FROM_EMAIL=5

# Weekly Brief (Phase 8.3) — manager digest emailed via gmail.send.
# Manual send (POST /digest/send) always works; these only gate the scheduled cron.
# day_of_week/hour use APScheduler cron semantics (mon..sun, 0-23, UTC).
WEEKLY_BRIEF_ENABLED=false
WEEKLY_BRIEF_DAY_OF_WEEK=mon
WEEKLY_BRIEF_HOUR=7

# Frontend (Next.js) — browser calls backend
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Docker Compose — published host ports (optional overrides; must match REDIS_PUBLISH_PORT / DATABASE_URL above)
# POSTGRES_PUBLISH_PORT=55432
# REDIS_PUBLISH_PORT=56379
# BACKEND_PUBLISH_PORT=8000
# FRONTEND_PUBLISH_PORT=3000
# MCP_DRIVE_PUBLISH_PORT=8787
# If only Postgres/Redis ports change on the host, also adjust DATABASE_URL / REDIS_URL for tools running on the host (not inside Compose).

# E2E — real Google account checks (scripts/mcp_real_account_check.py); never commit a real token
# E2E_GOOGLE_ACCESS_TOKEN=
# E2E_EXPECT_GOOGLE_EMAIL=
