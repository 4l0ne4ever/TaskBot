# Copy to .env and fill in sender/recipient.

# Account A — sends test mail (OAuth once via --auth; token saved as token.json)
GMAIL_TEST_SENDER=thuyetdoras.3@gmail.com

# Account B — TaskBot sync inbox (must match the account you OAuth-login in TaskBot)
GMAIL_TEST_RECIPIENT=emilywithherpet@gmail.com

# OAuth: reuses repo .env GOOGLE_CLIENT_ID/SECRET + GOOGLE_REDIRECT_URI (TaskBot Web client).
# Before --auth: docker compose stop backend  (port 8000)
# Override redirect only if needed:
# GMAIL_TEST_REDIRECT_URI=http://localhost:8000/auth/callback
